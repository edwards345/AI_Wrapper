{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/cli/**/*",
    "src/config/**/*",
    "src/engine/**/*",
    "src/providers/**/*",
    "src/test/**/*",
    "src/web/server.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
