{
  "name": "ai-wrapper",
  "version": "0.1.0",
  "description": "Multi-LLM prompt runner with consensus synthesis",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "aiwrapper": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc && cd src/web/client && npm run build",
    "start": "node dist/cli/index.js",
    "lint": "tsc --noEmit",
    "test": "tsx src/test/anthropic.test.ts",
    "server": "tsx src/web/server.ts",
    "client": "cd src/web/client && npm run dev",
    "web": "tsx src/web/server.ts & cd src/web/client && npm run dev",
    "build:client": "cd src/web/client && npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "cli",
    "anthropic",
    "openai",
    "gemini",
    "grok"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
